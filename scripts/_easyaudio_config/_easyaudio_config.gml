function _easyaudio_config() {
	// Set here your groups!
	#macro ESAU_GROUP_BGM grp_bgm
	#macro ESAU_GROUP_SFX grp_sfx
	#macro ESAU_GROUP_VOICES grp_voices
	
	// Set here your volume values!
	#macro ESAU_VOLUME_BGM global.bgm_volume
	#macro ESAU_VOLUME_SFX global.sfx_volume
	#macro ESAU_VOLUME_VOICES global.voices_volume
}

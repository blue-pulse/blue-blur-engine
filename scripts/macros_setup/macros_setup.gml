// Macros for general variables
#macro paused global.game_is_paused

// Macros for delta time
#macro delta_real global.delta_multiplier
#macro delta global.delta_override

// Macros for directions
#macro right 1
#macro left -1
#macro up 2
#macro down -2

// Macros for objects
#macro Screen global
#macro Window global
#macro Stage obj_stage
#macro Player obj_player
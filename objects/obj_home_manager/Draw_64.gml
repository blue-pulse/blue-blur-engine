draw_text_font_ext(WIDTH/2, HEIGHT/2 - 20, $"slot {selected_slot} will be used", font_black, fa_center, fa_middle, 1, c_white, 1);
draw_text_font_ext(WIDTH/2, HEIGHT/2, "press enter to continue", font_black, fa_center, fa_middle, 1, c_white, 1);
draw_text_font_ext(WIDTH/2, HEIGHT/2 + 20, "press esc to exit", font_black, fa_center, fa_middle, 1, c_white, 1);
draw_text_font_ext(WIDTH/2, HEIGHT/2 + 40, "press tab to toggle fullscreen", font_black, fa_center, fa_middle, 1, c_white, 1);
